#, kde-format
msgctxt "NAME OF TRANSLATORS"
msgid "Your names"
msgstr "ຊື່ຂອງທ່ານ"

#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr "ອີເມວຂອງທ່ານ"

#, kde-format
msgid "Circle by Center && Line"
msgstr "ວົງມົນດ້ວຍຈຸດໃຈກາງ && ເສັ້ນ"

#, kde-format
msgid "A circle constructed by its center and tangent to a given line"
msgstr "ວົງມົນທີ່ສ້າງຂຶ້ນດ້ວຍຈຸດໃຈກາງ ແລະ ຕິດກັບເສັ້ນທີ່ກຳນົດໃຫ້"

#, kde-format
msgid "Construct a circle tangent to this line"
msgstr "ສ້າງວົງມົນທີ່ຕິດກັບເສັ້ນນີ້"

#, kde-format
msgid "Select the line that the new circle should be tangent to..."
msgstr "ເລືອກເສັ້ນທີ່ວົງມົນໃໝ່ຄວນຈະຕິດກັບ..."

#, kde-format
msgid "Circle by Point && Segment (as the Diameter)"
msgstr "ວົງມົນດ້ວຍຈຸດ && ທ່ອນເສັ້ນ (ເປັນເສັ້ນຜ່າໃຈກາງ)"

#, kde-format
msgid ""
"A circle defined by its center and the length of a segment as the diameter"
msgstr "ວົງມົນທີ່ກຳນົດໂດຍຈຸດໃຈກາງ ແລະ ຄວາມຍາວຂອງທ່ອນເສັ້ນເປັນເສັ້ນຜ່າໃຈກາງ"

#, kde-format
msgid ""
"Construct a circle with the diameter given by the length of this segment"
msgstr "ສ້າງວົງມົນດ້ວຍເສັ້ນຜ່າໃຈກາງທີ່ກຳນົດໂດຍຄວາມຍາວຂອງທ່ອນເສັ້ນນີ້"

#, kde-format
msgid "Select the segment whose length gives the diameter of the new circle..."
msgstr "ເລືອກທ່ອນເສັ້ນທີ່ມີຄວາມຍາວເປັນເສັ້ນຜ່າໃຈກາງຂອງວົງມົນໃໝ່..."

#, kde-format
msgid "Equilateral Triangle"
msgstr "ຮູບສາມແຈສະເໝີ"

#, kde-format
msgid "Equilateral triangle with given two vertices"
msgstr "ຮູບສາມແຈສະເໝີກັບສອງຈຸດຈອມທີ່ກຳນົດໃຫ້"

#, kde-format
msgid "Evolute"
msgstr "Evolute"

#, kde-format
msgid "Evolute of a curve"
msgstr "Evolute ຂອງເສັ້ນໂຄ້ງ"

#, kde-format
msgid "Evolute of this curve"
msgstr "Evolute ຂອງເສັ້ນໂຄ້ງນີ້"

#, kde-format
msgid "Osculating Circle"
msgstr "ວົງມົນແນບ"

#, kde-format
msgid "Osculating circle of a curve at a point"
msgstr "ວົງມົນແນບຂອງເສັ້ນໂຄ້ງຢູ່ທີ່ຈຸດໜຶ່ງ"

#, kde-format
msgid "Osculating circle of this curve"
msgstr "ວົງມົນແນບຂອງເສັ້ນໂຄ້ງນີ້"

#, kde-format
msgid "Osculating circle at this point"
msgstr "ວົງມົນແນບຢູ່ທີ່ຈຸດນີ້"

#, kde-format
msgid "Select the point..."
msgstr "ເລືອກຈຸດ..."

#, kde-format
msgid "Square"
msgstr "ຮູບສີ່ແຈສະເໝີ"

#, kde-format
msgid "Square with two given adjacent vertices"
msgstr "ຮູບສີ່ແຈສະເໝີກັບສອງຈຸດຈອມທີ່ຢູ່ຕິດກັນ"

#, kde-format
msgid "Vector Difference"
msgstr "ຜົນລົບເວັກເຕີ"

#, kde-format
msgid "Construct the vector difference of two vectors."
msgstr "ສ້າງຜົນລົບເວັກເຕີຂອງສອງເວັກເຕີ."

#, kde-format
msgid "Construct the vector difference of this vector and another one."
msgstr "ສ້າງຜົນລົບເວັກເຕີຂອງເວັກເຕີນີ້ ແລະ ອີກອັນໜຶ່ງ."

#, kde-format
msgid "Construct the vector difference of the other vector and this one."
msgstr "ສ້າງຜົນລົບເວັກເຕີຂອງເວັກເຕີອື່ນ ແລະ ອັນນີ້."

#, kde-format
msgid "Construct the vector difference starting at this point."
msgstr "ສ້າງຜົນລົບເວັກເຕີໂດຍເລີ່ມຈາກຈຸດນີ້."

#, kde-format
msgid ""
"Select the first of the two vectors of which you want to construct the "
"difference..."
msgstr "ເລືອກເວັກເຕີທີໜຶ່ງຈາກສອງເວັກເຕີທີ່ທ່ານຕ້ອງການສ້າງຜົນລົບ..."

#, kde-format
msgid ""
"Select the other of the two vectors of which you want to construct the "
"difference..."
msgstr "ເລືອກເວັກເຕີທີສອງຈາກສອງເວັກເຕີທີ່ທ່ານຕ້ອງການສ້າງຜົນລົບ..."

#, kde-format
msgid "Select the point to construct the difference vector in..."
msgstr "ເລືອກຈຸດທີ່ຈະສ້າງເວັກເຕີຜົນລົບໃສ່..."

