#: objects/transform_types.cc:890
msgid "Apply a similitude mapping a point onto this point"
msgstr "ໃຊ້ການຄ້າຍຄືກັນທີ່ແຜນທີ່ຈຸດໃດໜຶ່ງໄປໃສ່ຈຸດນີ້"

#: objects/transform_types.cc:891
msgid ""
"Select the point onto which the similitude should map the first point..."
msgstr "ເລືອກຈຸດທີ່ການຄ້າຍຄືກັນຄວນຈະແຜນທີ່ຈຸດທຳອິດໃສ່..."

#: objects/vector_type.cc:12
msgid "Construct a vector from this point"
msgstr "ສ້າງເວັກເຕີຈາກຈຸດນີ້"

#: objects/vector_type.cc:12
msgid "Select the start point of the new vector..."
msgstr "ເລືອກຈຸດເລີ່ມຕົ້ນຂອງເວັກເຕີໃໝ່..."

#: objects/vector_type.cc:13
msgid "Construct a vector to this point"
msgstr "ສ້າງເວັກເຕີໄປຫາຈຸດນີ້"

#: objects/vector_type.cc:13
msgid "Select the end point of the new vector..."
msgstr "ເລືອກຈຸດສິ້ນສຸດຂອງເວັກເຕີໃໝ່..."

#: objects/vector_type.cc:44
msgid "Construct the vector sum of this vector and another one."
msgstr "ສ້າງຜົນບວກເວັກເຕີຂອງເວັກເຕີນີ້ ແລະ ອີກອັນໜຶ່ງ."

#: objects/vector_type.cc:45
msgid ""
"Select the first of the two vectors of which you want to construct the sum..."
msgstr "ເລືອກເວັກເຕີທຳອິດຈາກສອງອັນທີ່ທ່ານຕ້ອງການສ້າງຜົນບວກ..."

#: objects/vector_type.cc:48
msgid "Construct the vector sum of this vector and the other one."
msgstr "ສ້າງຜົນບວກເວັກເຕີຂອງເວັກເຕີນີ້ ແລະ ອີກອັນໜຶ່ງ."

#: objects/vector_type.cc:49
msgid ""
"Select the other of the two vectors of which you want to construct the sum..."
msgstr "ເລືອກເວັກເຕີອື່ນຈາກສອງອັນທີ່ທ່ານຕ້ອງການສ້າງຜົນບວກ..."

#: objects/vector_type.cc:51
msgid "Construct the vector sum starting at this point."
msgstr "ສ້າງຜົນບວກເວັກເຕີເລີ່ມຕົ້ນທີ່ຈຸດນີ້."

#: objects/vector_type.cc:51
msgid "Select the point to construct the sum vector in..."
msgstr "ເລືອກຈຸດເພື່ອສ້າງເວັກເຕີຜົນບວກ..."

