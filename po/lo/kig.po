msgstr "ປ້ອນໂຄ້ດ"

#: scripting/script-common.cc:18
#, kde-format
msgid "Now fill in the code:"
msgstr "ດຽວນີ້ໃຫ້ຕື່ມໂຄ້ດໃສ່:"

#: scripting/script-common.cc:19
#, kde-format
