#~ msgid ""
#~ "<p>You can control a kig construction by means of a \"pykig\" \n"
#~ "python script, that can be executed with the command \n"
#~ "<code>pykig.py</code>.  Here is a nice example \n"
#~ "(<code>hexagons.kpy</code>) you can try:\n"
#~ "<code><pre>\n"
#~ "kigdocument.hideobjects()\n"
#~ "def hexagons (c, v, n):\n"
#~ "  hexagon = PolygonBCV (c, v, 6)\n"
#~ "  if n &lt;= 0:\n"
#~ "    hexagon.show()\n"
#~ "    for i in range(6): \n"
#~ "      PolygonSide (hexagon, i, True)\n"
#~ "    return\n"
#~ "  cnew = MidPoints (c, v)\n"
#~ "  hexagons (cnew, v, n-1)\n"
#~ "  for k in [2,4]:\n"
#~ "    v1 = PolygonVertex (hexagon, k)\n"
#~ "    cnew = MidPoints (c, v1)\n"
#~ "    hexagons (cnew, v1, n-1)\n"
#~ "hexagons (Point(0,0), Point(1,0), 5)\n"
#~ "</pre></code>\n"
#~ msgstr ""
#~ "<p>бһўбҹ’бһ“бһҖвҖӢбһўбһ¶бһ…вҖӢбһҸбҹ’бһҡбһҪбһҸбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһҖбһ¶вҖӢбһҡбһҹбҹ’бһҗбһ¶бһ”бһ“бһ¶вҖӢбһҸбһ¶бһҳвҖӢбһҳбһ’бҹ’бһҷбҹ„бһ”бһ¶бһҷвҖӢбһҡбһ”бһҹбҹӢвҖӢбһҹбҹ’бһӮбҹ’бһҡбһёбһ” python \"pykig\" \n"
#~ "бһҠбҹӮбһӣвҖӢбһўбһ¶бһ…вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·вҖӢбһҮбһ¶вҖӢбһҳбһҪбһҷбһ“бһ№бһ„вҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһ”бһүбҹ’бһҮбһ¶\n"
#~ "<code>pykig.py</code> бҹ” бһ“бҹҒбҹҮвҖӢбһҮбһ¶вҖӢбһ§бһ‘бһ¶бһ бһҡбһҺбҹҚвҖӢбһҠбҹҸвҖӢбһӣбҹ’бһўвҖӢбһҳбһҪбһҷ\n"
#~ "(<code>hexagons.kpy</code>) бһҠбҹӮбһӣвҖӢбһўбҹ’бһ“бһҖвҖӢбһўбһ¶бһ…вҖӢбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„вҖӢбһ”бһ¶бһ“ бҹ–\n"
#~ "<code><pre>\n"
#~ "kigdocument.hideobjects()\n"
#~ "def hexagons (c, v, n):\n"
#~ "  hexagon = PolygonBCV (c, v, 6)\n"
#~ "  if n &lt;= 0:\n"
#~ "    hexagon.show()\n"
#~ "    for i in range(6): \n"
#~ "      PolygonSide (hexagon, i, True)\n"
#~ "    return\n"
#~ "  cnew = MidPoints (c, v)\n"
#~ "  hexagons (cnew, v, n-1)\n"
#~ "  for k in [2,4]:\n"
#~ "    v1 = PolygonVertex (hexagon, k)\n"
#~ "    cnew = MidPoints (c, v1)\n"
#~ "    hexagons (cnew, v1, n-1)\n"
#~ "hexagons (Point(0,0), Point(1,0), 5)\n"
#~ "</pre></code>\n"

